<configuration>
  <system.webServer>
    <environmentVariables>
      <add name="CAPTCHA_SECRET_KEY" value="your-secret-key" />
    </environmentVariables>
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>
    <iisnode node_env="production" />
    <rewrite>
      <rules>
        <!-- Rule to handle Node.js server file -->
        <rule name="NodeJS Server" stopProcessing="true">
          <match url="server.js" />
          <action type="Rewrite" url="server.js" />
        </rule>
        <!-- Rule to handle API requests (matches /send-email, /send-email-sms, with or without trailing slash, and any extra path) -->
        <rule name="API Requests" stopProcessing="true">
          <match url="send-email(-sms)?(/.*)?" />
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>
    <security>
      <requestFiltering>
        <verbs>
          <add verb="*" allowed="true" />
        </verbs>
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>